---
export interface Props {
  checkingLabel?: string
  errorMessage?: string
  idPrefix?: string
  passwordLabel?: string
  redirectTo?: string
  submitLabel?: string
  validationPath?: string
}

const DEFAULT_REDIRECT_PARAM = 'redirect'
const ROOT_PATH = '/'

const safeRedirectTarget = (value?: string | null) => {
  if (!value) return ROOT_PATH
  if (value.startsWith(ROOT_PATH) && !value.startsWith('//')) return value
  return ROOT_PATH
}

const {
  checkingLabel = 'Checking...',
  errorMessage = 'Password verification failed.',
  idPrefix = 'apd',
  passwordLabel = 'Password',
  redirectTo = safeRedirectTarget(
    Astro.url.searchParams.get(DEFAULT_REDIRECT_PARAM),
  ),
  submitLabel = 'Unlock',
  validationPath,
} = Astro.props

const fieldId = `${idPrefix}-field`
const formId = `${idPrefix}-form`
const errorId = `${idPrefix}-error`
const inputId = `${idPrefix}-input`
const submitId = `${idPrefix}-submit`
---

<form
  data-astro-password-form
  data-checking-label={checkingLabel}
  data-error-message={errorMessage}
  data-redirect-to={redirectTo}
  data-submit-label={submitLabel}
  data-validation-path={validationPath}
  id={formId}>
  <label for={inputId} id={fieldId}>
    {passwordLabel}
    <input
      aria-describedby={errorId}
      autocomplete="current-password"
      autofocus
      data-astro-password-input
      id={inputId}
      name="password"
      required
      type="password"
    />
  </label>
  <p aria-live="polite" data-astro-password-error hidden id={errorId} role="alert">
  </p>
  <button
    data-astro-password-submit
    data-status="empty"
    disabled
    id={submitId}
    type="submit">
    {submitLabel}
  </button>
</form>

<script>
  const safeTarget = (value: string) => {
    try {
      const url = new URL(value, window.location.origin)
      if (url.origin !== window.location.origin) return '/'

      return `${url.pathname}${url.search}${url.hash}`
    } catch {
      return '/'
    }
  }

  document
    .querySelectorAll<HTMLFormElement>('[data-astro-password-form]')
    .forEach(form => {
      if (form.dataset.astroPasswordReady) return

      form.dataset.astroPasswordReady = 'true'
      const input = form.querySelector<HTMLInputElement>(
        '[data-astro-password-input]',
      )
      const error = form.querySelector<HTMLParagraphElement>(
        '[data-astro-password-error]',
      )
      const submit = form.querySelector<HTMLButtonElement>(
        '[data-astro-password-submit]',
      )
      if (!input || !error || !submit) return

      const setError = (message: string) => {
        error.textContent = message
        error.hidden = !message
        input.toggleAttribute('aria-invalid', Boolean(message))
      }

      const updateButton = (loading: boolean) => {
        const status = loading ? 'loading' : input.value ? 'ready' : 'empty'
        submit.dataset.status = status
        submit.disabled = status !== 'ready'
        submit.textContent = loading
          ? form.dataset.checkingLabel || 'Checking...'
          : form.dataset.submitLabel || 'Unlock'

        if (loading) {
          submit.setAttribute('aria-busy', 'true')
          return
        }

        submit.removeAttribute('aria-busy')
      }

      input.addEventListener('input', () => {
        setError('')
        updateButton(false)
      })

      form.addEventListener('submit', async event => {
        event.preventDefault()
        if (!input.value) return
        setError('')
        updateButton(true)

        try {
          const target = safeTarget(form.dataset.redirectTo || '/')
          const validationTarget = safeTarget(
            form.dataset.validationPath ||
              `${window.location.pathname}${window.location.search}`,
          )
          const response = await fetch(validationTarget, {
            body: JSON.stringify({ password: input.value }),
            cache: 'no-store',
            credentials: 'same-origin',
            headers: {
              'content-type': 'application/json',
            },
            method: 'POST',
          })

          if (response.ok) {
            window.location.assign(target)
            return
          }

          setError(form.dataset.errorMessage || 'Password verification failed.')
        } catch {
          setError(form.dataset.errorMessage || 'Password verification failed.')
        } finally {
          updateButton(false)
        }
      })

      updateButton(false)
    })
</script>

<style>
  #apd-form {
    display: grid;
    gap: 0;
  }

  #apd-field {
    display: grid;
    gap: 8px;
    margin-bottom: 8px;
    color: #374151;
    font-size: 14px;
    font-weight: 500;
  }

  #apd-input {
    box-sizing: border-box;
    width: 100%;
    height: 38px;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    background: #ffffff;
    color: #111827;
    font: inherit;
    letter-spacing: 0.1em;
    padding: 0 12px;
    outline: none;
    transition:
      border-color 120ms ease,
      box-shadow 120ms ease;
  }

  #apd-input:focus {
    border-color: #9ca3af;
    box-shadow: 0 0 0 3px rgba(156, 163, 175, 0.28);
  }

  #apd-submit {
    user-select: none;
    box-sizing: border-box;
    display: inline-flex;
    height: 40px;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 8px;
    background: #111827;
    color: #ffffff;
    cursor: pointer;
    font: inherit;
    font-size: 14px;
    font-weight: 500;
    transition:
      background 120ms ease,
      opacity 120ms ease;
  }

  #apd-submit:not(:disabled):hover {
    background: #1f2937;
  }

  #apd-submit:disabled,
  #apd-submit[data-status='empty'] {
    cursor: not-allowed;
    opacity: 0.7;
  }

  #apd-submit[data-status='loading'] {
    cursor: wait;
    opacity: 0.7;
  }

  #apd-error {
    min-height: 20px;
    margin: 0 0 12px;
    color: #b91c1c;
    font-size: 13px;
  }

  #apd-error[hidden] {
    display: block;
    visibility: hidden;
  }
</style>
