{
  "name": "astro-password",
  "version": "0.2.3",
  "description": "Password protection middleware for Astro.",
  "homepage": "https://github.com/unix/astro-password#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unix/astro-password.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/unix/astro-password/issues"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./components/index.d.ts",
      "import": "./components/index.js"
    }
  },
  "files": [
    "components",
    "dist",
    "fonts",
    "LICENSE",
    "protected.astro",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "release": "pnpm build && pnpm publish --access public --no-git-checks",
    "lint": "eslint src",
    "prettier": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "astro",
    "astro-component",
    "astro-integration",
    "withastro",
    "password",
    "middleware",
    "auth"
  ],
  "peerDependencies": {
    "astro": ">=5.0.0"
  }
}
