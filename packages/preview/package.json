{
  "name": "preview",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter astro-password build && astro build",
    "release": "pnpm run build && wrangler deploy",
    "dev": "pnpm --filter astro-password build && astro dev --port 4320",
    "lint": "eslint src",
    "prettier": "prettier --write .",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^6.4.8",
    "astro-password": "workspace:*",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "vite": "^8.0.16",
    "wrangler": "^4.103.0"
  }
}
